# --- REQUIRED -------------------------------------------------------------
# Your Railway-hosted relay URL (use wss:// with the same hostname).
AXON_RELAY_URL=wss://your-relay.up.railway.app/v1/ws/agent

# Must match PC_AGENT_TOKEN in the relay's environment.
AXON_AGENT_TOKEN=replace-with-the-pc-agent-token

# --- OPTIONAL -------------------------------------------------------------
# Defaults to "pc". Set to "bridge" for the Pi (use bridge/ folder instead).
AXON_AGENT_ROLE=pc

# Defaults to the host's gethostname() if unset.
# AXON_AGENT_ID=denis-desktop

# Whitelist YAML location. Default: ./whitelist.yaml
AXON_WHITELIST_PATH=./whitelist.yaml
