AXON_RELAY_URL=wss://your-relay.up.railway.app/v1/ws/agent
AXON_BRIDGE_TOKEN=replace-with-the-bridge-agent-token
AXON_TARGET_MAC=AA:BB:CC:DD:EE:FF

# Default 255.255.255.255. If your router drops global broadcasts, use the
# subnet broadcast (e.g. 192.168.1.255). Look up your subnet with `ip a`.
# AXON_BROADCAST=192.168.1.255

# Default 9. Some networks prefer 7. Either works as long as the NIC accepts it.
# AXON_WOL_PORT=9

# Default: hostname.
# AXON_AGENT_ID=axon-bridge-pi
