# --- REQUIRED -------------------------------------------------------------
# Bearer token your phone (Siri Shortcuts) and dashboard present.
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
USER_API_KEY=replace-with-64-hex-chars

# Agent tokens. Each agent has its own token. Generate the same way.
PC_AGENT_TOKEN=replace-with-64-hex-chars
BRIDGE_AGENT_TOKEN=replace-with-64-hex-chars

# --- OPTIONAL -------------------------------------------------------------
# General rate limit (per token, requests/minute). Default 60.
RATE_LIMIT_PER_MIN=60

# Stricter limit for power.* commands. Default 10.
POWER_RATE_LIMIT_PER_MIN=10

# How long the relay waits for the agent to ack a command. Default 8s.
COMMAND_TIMEOUT_SECS=8

# Replay window in seconds. Reject commands with |now - ts| > this. Default 120.
REPLAY_WINDOW_SECS=120

# Where the JSONL audit log is written. Default ./audit.jsonl
AUDIT_LOG_PATH=./audit.jsonl

# Listen port. Railway sets this automatically.
PORT=8080
